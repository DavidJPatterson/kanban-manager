{
  "manifest_version": 3,
  "name": "Kanban Manager",
  "version": "1.3.3",
  "description": "Multi-pod Kanban dashboard with flow metrics, cycle time analytics, and health charts for Azure DevOps",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": ["https://dev.azure.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kanban Manager",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": ["print-export.html", "print-export.js", "print-export.css", "shared.js", "weekly-update.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
