{
  "manifest_version": 3,
  "name": "Kanban Manager",
  "version": "1.3.1",
  "description": "Multi-pod Kanban dashboard with flow metrics, cycle time analytics, and health charts for Azure DevOps",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://dev.azure.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Kanban Manager",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options.html"
}
